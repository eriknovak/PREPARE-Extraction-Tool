# =============================================================================
# PREPARE Extraction Tool - Environment Configuration
# =============================================================================

# Docker configuration
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
DOCKER_IMAGE_BIONER=bioner
TAG=latest

# Project name
PROJECT_NAME="PREPARE Extraction Tool"
STACK_NAME=prepare-usage-tool-project

# Service-to-service hosts. These are LOCAL defaults (for running services
# directly on the host). docker-compose overrides the cross-service ones with
# the compose service names (bioner:5600, backend:8000) automatically — so you
# do NOT need to change these when running via docker-compose.
FRONTEND_HOST=http://localhost:3000
# Frontend -> backend (vite dev proxy) and bioner -> backend (training callbacks)
BACKEND_HOST=http://localhost:8000
# Backend -> bioner (extraction + training control)
EXTRACT_HOST=http://localhost:5600

# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Backend CORS Origins - Allowed origins for cross-origin requests
# Format options:
#   1. Comma-separated: http://localhost:3000,http://localhost:8080
#   2. JSON array: ["http://localhost:3000","http://localhost:8080"]
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Environment: local, staging, production
ENVIRONMENT=local

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=changethis-generate-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL database
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Build the database URL
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}
# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Models
EMBEDDING_MODEL_SENTENCE=FremyCompany/BioLORD-2023-M

# BioNER
BIONER_ENGINE=gliner
# Model served on startup. Either a HuggingFace model id (downloaded into the
# persistent cache at ./.cache, see HuggingFace cache below) or a path to a local
# model inside the models library, e.g. BIONER_MODEL=/models/run-1-20260101_120000
#
# Local & trained models live in ./bioner/models (mounted read-write at /models):
#   - trained models are written there automatically, one folder per run
#     (run-<id>-<timestamp>); select one with BIONER_MODEL=/models/run-<id>-<ts>
#   - to use your own local model, drop it in ./bioner/models/<name> and set
#     BIONER_MODEL=/models/<name>
# Downloaded HuggingFace models are cached in ./.cache (mounted at /.cache,
# HF_HOME) and shared with the backend so they persist across restarts.
BIONER_MODEL=E3-JSI/gliner-multi-med-ner-synthetic-v1
BIONER_ADAPTER_MODEL=
BIONER_HOST=0.0.0.0
BIONER_PORT=5600
BIONER_USE_GPU=false
BIONER_ADAPTER_PATH=
BIONER_PROMPTS_PATH=
BIONER_HOST_PORT=5600
# Seconds to wait for a stopped training run's worker to wind down before a new
# run is reported as still stopping (409 TRAINING_STOPPING). Keep it small so the
# API stays responsive; the client retries.
TRAINING_STOP_JOIN_TIMEOUT=5.0
