.dev
.env
.env.prod
.claude
# Vendored project rules are the repo's own source of truth — keep them tracked
# even though .claude is otherwise local-only.
!**/.claude/
**/.claude/*
!**/.claude/project-rules/
# HuggingFace cache (persistent, shared by bioner + backend)
.cache/

# Local & trained model artifacts (folder created at runtime by the bioner volume)
bioner/models/

# devflow worktrees
.devflow
.claude/worktrees/
